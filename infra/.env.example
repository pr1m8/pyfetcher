# PostgreSQL
PG_USER=pyfetcher
PG_PASSWORD=pyfetcher
PG_DB=pyfetcher
PG_HOST=localhost
PG_PORT=5432

# MinIO (S3-compatible object store)
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# pyfetcher configuration
PYFETCHER_DATABASE_URL=postgresql+asyncpg://pyfetcher:pyfetcher@localhost:5432/pyfetcher
PYFETCHER_MINIO_ENDPOINT=localhost:9000
PYFETCHER_MINIO_ACCESS_KEY=minioadmin
PYFETCHER_MINIO_SECRET_KEY=minioadmin
PYFETCHER_MINIO_SECURE=false
PYFETCHER_MINIO_BUCKET=pyfetcher

# Pipeline concurrency
PYFETCHER_CRAWL_CONCURRENCY=10
PYFETCHER_SCRAPE_CONCURRENCY=20
PYFETCHER_DOWNLOAD_CONCURRENCY=5
PYFETCHER_DEFAULT_CRAWL_DELAY_SECONDS=1.0
PYFETCHER_MAX_RETRIES=3
